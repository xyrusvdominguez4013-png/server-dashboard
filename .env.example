# Server Monitor Dashboard - Environment Configuration

# Optional: Port to run the dashboard on (default: 5000)
PORT=5001

# List of agents to monitor. Format as a JSON array string.
# Each agent object should have: name, ip, and token
AGENTS_CONFIG='[{"name": "Web Server", "ip": "192.168.1.10", "token": "your-token-here"}, {"name": "DB Server", "ip": "192.168.1.11", "token": "another-token-here"}]'
